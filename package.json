{
  "name": "@gaubee/2fa-workspace",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:web": "pnpm --filter gaubee-2fa-web dev",
    "dev:admin": "pnpm --filter gaubee-2fa-server-admin dev",
    "build": "pnpm build:web && pnpm build:admin && cargo build --workspace",
    "build:web": "pnpm --filter gaubee-2fa-web build",
    "build:admin": "pnpm --filter gaubee-2fa-server-admin build",
    "lint": "pnpm lint:web && pnpm lint:admin && cargo test --workspace",
    "lint:web": "pnpm --filter gaubee-2fa-web lint",
    "lint:admin": "pnpm --filter gaubee-2fa-server-admin lint",
    "preview": "pnpm --filter gaubee-2fa-web preview",
    "preview:admin": "pnpm --filter gaubee-2fa-server-admin preview",
    "dev:server": "cargo run -p gaubee-2fa-server -- --http 127.0.0.1:8080 --grpc [::1]:50051 --db sqlite",
    "build:rust": "cargo build --workspace",
    "check:rust": "cargo test --workspace",
    "release:github": "tsx scripts/release.ts",
    "docker:up:sqlite": "docker compose -f infra/docker/docker-compose.sqlite.yml up -d --build",
    "docker:down:sqlite": "docker compose -f infra/docker/docker-compose.sqlite.yml down",
    "docker:up:postgres": "docker compose -f infra/docker/docker-compose.postgres.yml up -d --build",
    "docker:down:postgres": "docker compose -f infra/docker/docker-compose.postgres.yml down",
    "build:wasm": "tsx scripts/build-wasm.ts",
    "mobile:bindings": "tsx scripts/generate-mobile-bindings.ts",
    "mobile:android:rust": "tsx scripts/build-mobile-android-rust.ts",
    "mobile:android:assemble": "cd mobile/android && ./gradlew assembleDebug",
    "mobile:ios:rust": "tsx scripts/build-mobile-ios-rust.ts",
    "mobile:ios:project": "cd mobile/ios && xcodegen generate"
  },
  "devDependencies": {
    "lerna": "^8.2.1",
    "tsx": "^4.20.6"
  }
}
